[Unit]
Description=BirdNET-Go SSE to Pixoo bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/pixoo
EnvironmentFile=/etc/default/birdnet-sse
ExecStart=/opt/pixoo/run_birdnet_sse.sh
Restart=always
RestartSec=5
User=pi
Group=pi
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
